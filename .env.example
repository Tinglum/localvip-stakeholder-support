# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=LocalVIP Support

# QA OAuth / OIDC
NEXT_PUBLIC_QA_AUTH_BASE_URL=https://qa.localvip.com
QA_AUTH_CLIENT_ID=lvip_dashboard
QA_AUTH_SCOPES=openid profile email name LVIPDashboardApiV1 roles offline_access
# Optional: use these when QA has whitelisted a fixed redirect URI for the dashboard.
# QA_AUTH_REDIRECT_URI=http://dashboard.localvip.com/api/auth/qa/callback
# QA_AUTH_POST_LOGOUT_REDIRECT_URI=http://dashboard.localvip.com/

# Optional: QR Code short link domain
NEXT_PUBLIC_SHORT_LINK_DOMAIN=https://lvip.link
